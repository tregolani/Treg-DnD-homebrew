	<element name="Level 17: Unerring Accuracy" type="Archetype Feature" source="Tregolani Homebrew Collection for Solandria" id="ID_TREGOLANI_HB_ARCHETYPE_FEATURE_MONK_KENSEI_UNERRING_ACCURACY">
		<description>
			<p>Once per turn, when you miss an attack roll with a Kensei weapon, you may reroll it, and you must use the new roll.</p>
		</description>
		<sheet alt="Unerring Accuracy" usage="1/Turn">
			<description>When you miss an attack roll with a Kensei weapon, you may reroll it.</description>
		</sheet>
	</element>
	
