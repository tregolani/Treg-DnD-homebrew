	<element name="Deft Strike" type="Archetype Feature" source="Tregolani Homebrew Collection for Solandria" id="ID_TREGOLANI_HB_ARCHETYPE_FEATURE_MONK_KENSEI_ONE_WITH_THE_BLADE_DEFT_STRIKE">
